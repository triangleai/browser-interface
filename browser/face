#!/usr/bin/env bash
# browser/face — start the browserface bridge against a Chrome session,
# or run development / build commands. Run `browser/face --help` for docs.
set -euo pipefail

# Single source of truth for both wrapper-level and bridge-level docs.
# Called by --help / -h / help and by the unknown-command default below.
usage() {
  cat <<'EOF'
browser/face — start the browserface bridge against a Chrome session.

Usage:
  browser/face [bridge flags...]   start the bridge (default)
  browser/face dev [...flags]      dev mode (rebuild on changes)
  browser/face build               build server + client
  browser/face typecheck           tsc --noEmit
  browser/face clean               remove dist/

By default browser/face attaches to its dedicated agent Chrome profile at
~/.browserface/chrome (auto-runs browser/start to bring it up). Pass
--discover to attach to your own Chrome via the chrome://inspect-toggle
flow. Pass --target / --host / --port for an explicit endpoint.

Bridge flags:
  --target <url>           Full CDP WebSocket URL (browser- or page-level)
  --host <host>            CDP host (default 127.0.0.1)
  --port <port>            CDP port
  --discover               Attach to your own Chrome via the chrome://inspect
                           toggle flow (default: agent profile only)
  --listen-host <host>     HTTP/WS bind host (default 127.0.0.1)
  --listen-port <port>     HTTP/WS bind port (default 8768)
  --width <px>             Override viewport width
  --height <px>            Override viewport height
  --max-fps <n>            Cap emitted frames/sec (default 30; 0 disables)
  --format <png|jpeg>      Screenshot format (default jpeg)
  --quality <0-100>        JPEG quality (default 60)
EOF
}

# Intercept --help / -h / help in bash so it's instant — no Node startup
# tax for a command the user runs to read documentation.
for arg in "$@"; do
  case "$arg" in
    -h|--help|help)
      usage
      exit 0
      ;;
  esac
done

HERE="$(dirname "$0")"
cd "$HERE/.."

# Direct path to the local tsc binary so we skip `npm run` overhead
# (~100ms per invocation). `npm install` puts it here under any standard
# layout.
TSC="./node_modules/.bin/tsc"

# Always rebuild before starting. tsc (incremental) + esbuild are both
# near-instant when nothing changed, so this is cheaper than a stale-
# build footgun.
ensure_built() {
  [[ -d node_modules ]] || npm install
  "$TSC" -p tsconfig.server.json
  node scripts/build-client.mjs
}

# In default mode (no --discover, no explicit endpoint), bring up the agent
# Chrome profile via browser/start before launching the bridge. Idempotent:
# if Chrome is already running with that profile, this is a fast no-op.
# Skipped when the user explicitly opted into a different attachment path.
ensure_agent_chrome_if_default() {
  for arg in "$@"; do
    case "$arg" in
      --discover|--target|--target=*|--port|--port=*|--host|--host=*)
        return 0 ;;
    esac
  done
  "$HERE/start" >/dev/null
}

# No args, or first arg is a flag → bridge.
if [[ $# -eq 0 || "${1:0:1}" == "-" ]]; then
  ensure_built
  ensure_agent_chrome_if_default "$@"
  exec node dist/server/cli.js "$@"
fi

cmd="$1"; shift
case "$cmd" in
  dev)
    [[ -d node_modules ]] || npm install
    ensure_agent_chrome_if_default "$@"
    exec node scripts/dev.mjs "$@"
    ;;
  build|build:server|build:client|typecheck|clean)
    [[ -d node_modules ]] || npm install
    exec npm run "$cmd" -- "$@"
    ;;
  *)
    echo "Unknown command: $cmd" >&2
    echo >&2
    usage >&2
    exit 1
    ;;
esac
