#!/usr/bin/env bash
# Thin wrapper around the underlying npm scripts. Lets users run
# `browser/face` instead of remembering `npm start --` etc.
#
#   browser/face                     start bridge against the dedicated agent
#                                    Chrome profile (auto-runs browser/start)
#   browser/face --discover          attach to the daily-driver Chrome via
#                                    chrome://inspect-toggle flow
#   browser/face --port 9222         attach to a specific CDP port
#   browser/face dev [...flags]      dev mode (rebuild on changes)
#   browser/face build               build server + client
#   browser/face typecheck           tsc --noEmit
#   browser/face clean               remove dist/
#
# Bridge flags can be saved as defaults with `browser/config set bridge …`;
# they're layered on top of any CLI flags on every start/dev invocation,
# with per-flag suppression when the same flag is on the CLI.
#
set -euo pipefail

HERE="$(dirname "$0")"
cd "$HERE/.."

# Always rebuild before starting. tsc (incremental) + esbuild are both
# near-instant when nothing changed, so this is cheaper than a stale-
# build footgun.
ensure_built() {
  [[ -d node_modules ]] || npm install
  npm run build
}

# Read NUL-delimited merged bridge args from browser/config into the global
# `bridge_args` array. Done in a function so it can be reused by start/dev
# without duplicating the read loop (bash can't return arrays cleanly).
merge_bridge_args() {
  bridge_args=()
  while IFS= read -r -d '' arg; do
    bridge_args+=("$arg")
  done < <("$HERE/config" merge bridge -- "$@")
}

# In default mode (no --discover, no explicit endpoint), bring up the agent
# Chrome profile via browser/start before npm start. Idempotent: if Chrome
# is already running with that profile, this is a fast no-op. Skipped when
# the user explicitly opted into a different attachment path.
ensure_agent_chrome_if_default() {
  for arg in "$@"; do
    case "$arg" in
      --discover|--target|--target=*|-t|--port|--port=*|--host|--host=*)
        return 0 ;;
    esac
  done
  "$HERE/start" >/dev/null
}

# No args, or first arg is a flag → bridge.
if [[ $# -eq 0 || "${1:0:1}" == "-" ]]; then
  ensure_built
  merge_bridge_args "$@"
  ensure_agent_chrome_if_default "${bridge_args[@]+"${bridge_args[@]}"}"
  exec npm start -- "${bridge_args[@]+"${bridge_args[@]}"}"
fi

cmd="$1"; shift
case "$cmd" in
  start)
    ensure_built
    merge_bridge_args "$@"
    ensure_agent_chrome_if_default "${bridge_args[@]+"${bridge_args[@]}"}"
    exec npm start -- "${bridge_args[@]+"${bridge_args[@]}"}"
    ;;
  dev)
    [[ -d node_modules ]] || npm install
    merge_bridge_args "$@"
    ensure_agent_chrome_if_default "${bridge_args[@]+"${bridge_args[@]}"}"
    exec npm run dev -- "${bridge_args[@]+"${bridge_args[@]}"}"
    ;;
  build|build:server|build:client|typecheck|clean)
    [[ -d node_modules ]] || npm install
    exec npm run "$cmd" -- "$@"
    ;;
  -h|--help|help)
    sed -n '2,17p' "$0" | sed 's/^# \{0,1\}//'
    ;;
  *)
    echo "Unknown command: $cmd" >&2
    echo "Usage: browser/face [start|dev|build|typecheck|clean] [flags]" >&2
    exit 1
    ;;
esac
