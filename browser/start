#!/usr/bin/env bash
# browser/start — wrapper for src/server/start.ts.
# Run `browser/start --help` for full docs.
set -euo pipefail

HERE="$(dirname "$0")"
cd "$HERE/.."

# Make a fresh clone Just Work without requiring browser/face first.
# Both checks are no-ops on the second invocation, so the cost is paid
# once on a fresh clone or after a wipe.
[[ -d node_modules ]] || npm install
# Direct tsc invocation — skips the ~100ms `npm run` overhead and keeps
# any tsc output on stderr so stdout stays clean for the WS URL below.
[[ -f dist/server/start.js ]] || ./node_modules/.bin/tsc -p tsconfig.server.json >&2

exec node dist/server/start.js "$@"
