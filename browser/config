#!/usr/bin/env bash
# browser/config — manage persistent browserface configuration in ~/.browserface
#
# Usage:
#   browser/config set <domain> <args...>      Save a setting
#   browser/config show [<domain>]              Print one setting, or all if no domain
#   browser/config clear <domain>               Remove a setting
#   browser/config merge <domain> [-- args...]  Emit NUL-delimited args = CLI ∪ defaults
#
# Domains:
#   auth     ngrok auth flags applied by browser/share when no auth flag is on the CLI
#   bridge   bridge flags applied by browser/face when the matching flag is not on the CLI
#
# Storage: each domain has its own file at ~/.browserface/<domain>.
set -euo pipefail

CONFIG_DIR="${HOME}/.browserface"
KNOWN_DOMAINS=(auth bridge)

usage() {
  cat <<'EOF'
browser/config — manage persistent browserface configuration

Usage:
  browser/config set <domain> <args>
  browser/config show [<domain>]
  browser/config clear <domain>
  browser/config merge <domain> [-- args...]

Domains:
  auth     ngrok auth flags applied by browser/share when no auth flag is on the CLI
  bridge   bridge flags applied by browser/face when the matching flag is not on the CLI

Examples:
  browser/config set auth --oauth google --oauth-allow-email you@example.com
  browser/config set auth --cidr-allow 203.0.113.0/24
  browser/config set bridge --listen-port 9000 --max-fps 60
  browser/config set bridge --width 1440 --height 900 --format jpeg --quality 70
  browser/config show
  browser/config show bridge
  browser/config clear bridge

`merge` is for callers (browser/share, browser/face). It emits NUL-delimited
args on stdout: the CLI args you passed, plus any saved defaults that the
domain's merge policy says are not suppressed by the CLI. Read it with:

  args=()
  while IFS= read -r -d '' a; do args+=("$a"); done \
    < <(browser/config merge <domain> -- "$@")

Storage: ~/.browserface/<domain>.
EOF
}

is_known_domain() {
  local d="$1" k
  for k in "${KNOWN_DOMAINS[@]}"; do
    [[ "$d" == "$k" ]] && return 0
  done
  return 1
}

# ── auth ──────────────────────────────────────────────────────────────────
# Auth is one logical policy: any auth-related flag on the CLI suppresses
# the entire saved string. Recognized flags must stay in sync with the
# guard in browser/share.

auth_is_signal() {
  case "$1" in
    --oauth|--oauth=*|--oidc|--oidc=*|--cidr-allow|--cidr-allow=*|\
    --mutual-tls-cas|--mutual-tls-cas=*|\
    --traffic-policy-file|--traffic-policy-file=*|--auth-disabled)
      return 0 ;;
  esac
  return 1
}

auth_args_have_signal() {
  for arg in "$@"; do
    auth_is_signal "$arg" && return 0
  done
  return 1
}

domain_set_auth() {
  if [[ $# -eq 0 ]]; then
    echo "browser/config set auth: requires at least one auth flag" >&2
    echo "  e.g. browser/config set auth --oauth google --oauth-allow-email you@example.com" >&2
    echo "       browser/config set auth --auth-disabled  (no auth, anyone with the URL)" >&2
    exit 1
  fi
  if ! auth_args_have_signal "$@"; then
    echo "browser/config set auth: no recognized auth flag in arguments" >&2
    echo "  Valid: --oauth, --oidc, --cidr-allow, --mutual-tls-cas, --traffic-policy-file, --auth-disabled" >&2
    exit 1
  fi
  mkdir -p "$CONFIG_DIR"
  printf '%s\n' "$*" > "$CONFIG_DIR/auth"
  echo "browser/config: saved auth = $*" >&2
}

merge_auth() {
  local cli_args=("$@")
  local saved_args=()
  if ! auth_args_have_signal "${cli_args[@]+"${cli_args[@]}"}" && [[ -s "$CONFIG_DIR/auth" ]]; then
    local saved_str
    saved_str="$(cat "$CONFIG_DIR/auth")"
    # shellcheck disable=SC2206
    saved_args=($saved_str)
    echo "browser/config: applying auth defaults: $saved_str" >&2
  fi
  for arg in "${cli_args[@]+"${cli_args[@]}"}" "${saved_args[@]+"${saved_args[@]}"}"; do
    printf '%s\0' "$arg"
  done
}

# ── bridge ────────────────────────────────────────────────────────────────
# Bridge is a bag of independent knobs. Per-flag suppression: a saved flag
# is dropped from the merge only when the same canonical flag is on the
# CLI. Recognized flag names must stay in sync with src/server/cli.ts.

# Returns the canonical (long) form of a bridge flag, or empty if not
# recognized. Strips the =value suffix so "--listen-port=9000" canonicalizes
# to "--listen-port".
bridge_canonical_flag() {
  local f="${1%%=*}"
  case "$f" in
    -l) echo "--listen-port" ;;
    --listen-host|--listen-port|--width|--height|--max-fps|--format|--quality)
      echo "$f" ;;
    *) echo "" ;;
  esac
}

domain_set_bridge() {
  if [[ $# -eq 0 ]]; then
    echo "browser/config set bridge: requires at least one bridge flag" >&2
    echo "  e.g. browser/config set bridge --listen-port 9000 --max-fps 60" >&2
    exit 1
  fi
  local args=("$@")
  local i=0
  while [[ $i -lt ${#args[@]} ]]; do
    local arg="${args[$i]}"
    local c
    c="$(bridge_canonical_flag "$arg")"
    if [[ -z "$c" ]]; then
      echo "browser/config set bridge: unknown flag '$arg'" >&2
      echo "  Valid: --listen-host, --listen-port (-l), --width, --height, --max-fps, --format, --quality" >&2
      exit 1
    fi
    if [[ "$arg" == *=* ]]; then
      i=$((i+1))
    else
      if [[ $((i+1)) -ge ${#args[@]} ]]; then
        echo "browser/config set bridge: '$arg' requires a value" >&2
        exit 1
      fi
      i=$((i+2))
    fi
  done
  mkdir -p "$CONFIG_DIR"
  printf '%s\n' "$*" > "$CONFIG_DIR/bridge"
  echo "browser/config: saved bridge = $*" >&2
}

merge_bridge() {
  local cli_args=("$@")

  # Build the set of canonical bridge flags present on the CLI. Stored as
  # a space-padded string for membership tests (bash 3.2 has no native sets).
  local cli_flags=" "
  for arg in "${cli_args[@]+"${cli_args[@]}"}"; do
    local c
    c="$(bridge_canonical_flag "$arg")"
    [[ -n "$c" ]] && cli_flags+="$c "
  done

  local saved_args=()
  if [[ -s "$CONFIG_DIR/bridge" ]]; then
    local saved_str
    saved_str="$(cat "$CONFIG_DIR/bridge")"
    # shellcheck disable=SC2206
    saved_args=($saved_str)
  fi

  # Emit CLI args verbatim first, then any saved (flag, value) pair whose
  # canonical name isn't on the CLI. The whole pair is kept or dropped
  # together — never half a flag.
  for arg in "${cli_args[@]+"${cli_args[@]}"}"; do
    printf '%s\0' "$arg"
  done

  local applied=()
  local n=${#saved_args[@]}
  local i=0
  while [[ $i -lt $n ]]; do
    local s="${saved_args[$i]}"
    local c
    c="$(bridge_canonical_flag "$s")"
    if [[ -z "$c" ]]; then
      # Unknown saved token (shouldn't happen — set validates). Pass it
      # through and advance one.
      printf '%s\0' "$s"
      applied+=("$s")
      i=$((i+1))
      continue
    fi
    if [[ "$s" == *=* ]]; then
      if [[ "$cli_flags" != *" $c "* ]]; then
        printf '%s\0' "$s"
        applied+=("$s")
      fi
      i=$((i+1))
    else
      local v="${saved_args[$((i+1))]:-}"
      if [[ "$cli_flags" != *" $c "* ]]; then
        printf '%s\0' "$s"
        printf '%s\0' "$v"
        applied+=("$s" "$v")
      fi
      i=$((i+2))
    fi
  done

  if [[ ${#applied[@]} -gt 0 ]]; then
    echo "browser/config: applying bridge defaults: ${applied[*]}" >&2
  fi
}

# ── verbs ─────────────────────────────────────────────────────────────────

cmd_set() {
  if [[ $# -eq 0 ]]; then
    echo "browser/config set: missing domain (one of: ${KNOWN_DOMAINS[*]})" >&2
    exit 1
  fi
  local domain="$1"; shift
  if ! is_known_domain "$domain"; then
    echo "browser/config set: unknown domain '$domain' (one of: ${KNOWN_DOMAINS[*]})" >&2
    exit 1
  fi
  case "$domain" in
    auth)   domain_set_auth "$@" ;;
    bridge) domain_set_bridge "$@" ;;
  esac
}

cmd_show() {
  if [[ $# -eq 0 ]]; then
    local any=0 f name
    for name in "${KNOWN_DOMAINS[@]}"; do
      f="$CONFIG_DIR/$name"
      if [[ -s "$f" ]]; then
        printf '%s = %s\n' "$name" "$(cat "$f")"
        any=1
      fi
    done
    if [[ $any -eq 0 ]]; then echo "(no settings)"; fi
    return
  fi
  local domain="$1"
  if ! is_known_domain "$domain"; then
    echo "browser/config show: unknown domain '$domain' (one of: ${KNOWN_DOMAINS[*]})" >&2
    exit 1
  fi
  local f="$CONFIG_DIR/$domain"
  if [[ -s "$f" ]]; then
    cat "$f"
  else
    echo "(unset)"
  fi
}

cmd_clear() {
  if [[ $# -eq 0 ]]; then
    echo "browser/config clear: missing domain (one of: ${KNOWN_DOMAINS[*]})" >&2
    exit 1
  fi
  local domain="$1"
  if ! is_known_domain "$domain"; then
    echo "browser/config clear: unknown domain '$domain' (one of: ${KNOWN_DOMAINS[*]})" >&2
    exit 1
  fi
  local f="$CONFIG_DIR/$domain"
  if [[ -f "$f" ]]; then
    rm "$f"
    echo "browser/config: cleared $domain" >&2
  else
    echo "browser/config: $domain was already unset" >&2
  fi
}

cmd_merge() {
  if [[ $# -eq 0 ]]; then
    echo "browser/config merge: missing domain (one of: ${KNOWN_DOMAINS[*]})" >&2
    exit 1
  fi
  local domain="$1"; shift
  if ! is_known_domain "$domain"; then
    echo "browser/config merge: unknown domain '$domain' (one of: ${KNOWN_DOMAINS[*]})" >&2
    exit 1
  fi
  # Optional "--" separator before the CLI args.
  if [[ $# -gt 0 && "$1" == "--" ]]; then shift; fi
  case "$domain" in
    auth)   merge_auth "$@" ;;
    bridge) merge_bridge "$@" ;;
  esac
}

if [[ $# -eq 0 ]]; then
  usage
  exit 0
fi

case "$1" in
  -h|--help|help) usage; exit 0 ;;
  set)   shift; cmd_set "$@" ;;
  show)  shift; cmd_show "$@" ;;
  clear) shift; cmd_clear "$@" ;;
  merge) shift; cmd_merge "$@" ;;
  *)
    echo "browser/config: unknown verb '$1' (use set|show|clear|merge)" >&2
    exit 1
    ;;
esac
